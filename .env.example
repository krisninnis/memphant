# Project Brain — environment variables
# Copy this file to .env and fill in your values.
# ─── Supabase (cloud sync + auth) ─────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ─── Stripe (billing) ─────────────────────────────────────────────────────────
# Get Price IDs from: Stripe Dashboard → Products → your product → price ID
VITE_STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
VITE_STRIPE_TEAM_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx

# URL of your Vercel deployment (no trailing slash).
# Used as the base for API calls from the Tauri app.
VITE_API_URL=https://project-brain.vercel.app
