{
  "version": 2,
  "routes": [
    {
      "src": "/download",
      "headers": { "Location": "https://github.com/krisninnis/memphant/releases" },
      "status": 302,
      "continue": false
    },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/success", "dest": "/public/success.html" },
    { "src": "/cancel", "dest": "/public/cancel.html" },
    { "src": "/auth/callback", "dest": "/api/auth-callback" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
