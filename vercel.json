{
  "version": 2,
  "functions": {
    "api/*.ts": { "runtime": "@vercel/node" },
    "api/*.js": { "runtime": "@vercel/node" }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/success",  "dest": "/public/success.html" },
    { "src": "/cancel",   "dest": "/public/cancel.html" },
    { "src": "/",         "dest": "/public/index.html" },
    { "src": "/(.*)",     "dest": "/public/$1" }
  ]
}
