<svg viewBox="0 0 1340 680" width="100%" xmlns="http://www.w3.org/2000/svg" role="img" style="">
  <title style="fill:rgb(0, 0, 0);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto">Memephant — Switch AI tools without losing context</title>
  <desc style="fill:rgb(0, 0, 0);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto">Social share image for Memephant</desc>

  <rect width="1200" height="630" fill="#0f0f1a" style="fill:rgb(15, 15, 26);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

  <!-- Subtle grid pattern -->
  <defs>
    <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
      <path d="M 60 0 L 0 0 0 60" fill="none" stroke="#ffffff" stroke-width="0.3" opacity="0.06"/>
    </pattern>
  </defs>
  <rect width="1200" height="630" fill="url(#grid)" style="stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

  <!-- Accent glow blob top right -->
  <ellipse cx="1050" cy="120" rx="280" ry="180" fill="#d97706" opacity="0.06" style="fill:rgb(217, 119, 6);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.06;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <!-- Accent glow blob bottom left -->
  <ellipse cx="160" cy="530" rx="220" ry="140" fill="#6366f1" opacity="0.07" style="fill:rgb(99, 102, 241);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.07;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

  <!-- Elephant silhouette — simple geometric shape -->
  <g transform="translate(88, 180)" opacity="0.9" style="fill:rgb(0, 0, 0);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.9;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto">
    <!-- Body -->
    <ellipse cx="90" cy="110" rx="72" ry="62" fill="#d97706" opacity="0.85" style="fill:rgb(217, 119, 6);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.85;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <!-- Head -->
    <ellipse cx="148" cy="70" rx="48" ry="44" fill="#d97706" opacity="0.85" style="fill:rgb(217, 119, 6);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.85;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <!-- Trunk -->
    <path d="M 172 90 Q 210 110 200 148 Q 195 170 185 168" fill="none" stroke="#d97706" stroke-width="18" stroke-linecap="round" opacity="0.85" style="fill:none;stroke:rgb(217, 119, 6);color:rgb(0, 0, 0);stroke-width:18px;stroke-linecap:round;stroke-linejoin:miter;opacity:0.85;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <!-- Ear -->
    <ellipse cx="118" cy="58" rx="24" ry="32" fill="#b45309" opacity="0.9" style="fill:rgb(180, 83, 9);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.9;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <!-- Eye -->
    <circle cx="158" cy="58" r="6" fill="#0f0f1a" style="fill:rgb(15, 15, 26);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <circle cx="160" cy="56" r="2" fill="#ffffff" opacity="0.6" style="fill:rgb(255, 255, 255);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.6;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <!-- Legs -->
    <rect x="44" y="158" width="26" height="48" rx="13" fill="#b45309" opacity="0.85" style="fill:rgb(180, 83, 9);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.85;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <rect x="78" y="162" width="26" height="44" rx="13" fill="#b45309" opacity="0.85" style="fill:rgb(180, 83, 9);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.85;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <rect x="112" y="162" width="26" height="44" rx="13" fill="#b45309" opacity="0.85" style="fill:rgb(180, 83, 9);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.85;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <rect x="142" y="158" width="26" height="48" rx="13" fill="#b45309" opacity="0.85" style="fill:rgb(180, 83, 9);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.85;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <!-- Tusk -->
    <path d="M 176 96 Q 200 104 196 120" fill="none" stroke="#fef3c7" stroke-width="7" stroke-linecap="round" opacity="0.7" style="fill:none;stroke:rgb(254, 243, 199);color:rgb(0, 0, 0);stroke-width:7px;stroke-linecap:round;stroke-linejoin:miter;opacity:0.7;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  </g>

  <!-- Wordmark -->
  <text x="290" y="252" font-family="system-ui, -apple-system, sans-serif" font-size="88" font-weight="700" fill="#ffffff" letter-spacing="-2" style="fill:rgb(255, 255, 255);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:system-ui, -apple-system, sans-serif;font-size:88px;font-weight:700;text-anchor:start;dominant-baseline:auto">Memephant</text>

  <!-- Tagline -->
  <text x="292" y="322" font-family="system-ui, -apple-system, sans-serif" font-size="36" font-weight="400" fill="#94a3b8" letter-spacing="0.2" style="fill:rgb(148, 163, 184);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:system-ui, -apple-system, sans-serif;font-size:36px;font-weight:400;text-anchor:start;dominant-baseline:auto">Switch AI tools without losing context</text>

  <!-- Divider -->
  <rect x="292" y="360" width="580" height="2" rx="1" fill="#d97706" opacity="0.5" style="fill:rgb(217, 119, 6);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.5;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

  <!-- Platform pills -->
  <g transform="translate(292, 388)" style="fill:rgb(0, 0, 0);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto">
    <!-- ChatGPT -->
    <rect x="0" y="0" width="130" height="38" rx="19" fill="#10a37f" opacity="0.2" style="fill:rgb(16, 163, 127);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.2;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <rect x="0" y="0" width="130" height="38" rx="19" fill="none" stroke="#10a37f" stroke-width="1" opacity="0.4" style="fill:none;stroke:rgb(16, 163, 127);color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.4;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <text x="65" y="24" font-family="system-ui, sans-serif" font-size="16" font-weight="500" fill="#10a37f" text-anchor="middle" opacity="0.9" style="fill:rgb(16, 163, 127);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.9;font-family:system-ui, sans-serif;font-size:16px;font-weight:500;text-anchor:middle;dominant-baseline:auto">ChatGPT</text>
    <!-- Claude -->
    <rect x="146" y="0" width="110" height="38" rx="19" fill="#d97706" opacity="0.2" style="fill:rgb(217, 119, 6);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.2;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <rect x="146" y="0" width="110" height="38" rx="19" fill="none" stroke="#d97706" stroke-width="1" opacity="0.4" style="fill:none;stroke:rgb(217, 119, 6);color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.4;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <text x="201" y="24" font-family="system-ui, sans-serif" font-size="16" font-weight="500" fill="#d97706" text-anchor="middle" opacity="0.9" style="fill:rgb(217, 119, 6);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.9;font-family:system-ui, sans-serif;font-size:16px;font-weight:500;text-anchor:middle;dominant-baseline:auto">Claude</text>
    <!-- Gemini -->
    <rect x="272" y="0" width="118" height="38" rx="19" fill="#8b5cf6" opacity="0.2" style="fill:rgb(139, 92, 246);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.2;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <rect x="272" y="0" width="118" height="38" rx="19" fill="none" stroke="#8b5cf6" stroke-width="1" opacity="0.4" style="fill:none;stroke:rgb(139, 92, 246);color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.4;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <text x="331" y="24" font-family="system-ui, sans-serif" font-size="16" font-weight="500" fill="#8b5cf6" text-anchor="middle" opacity="0.9" style="fill:rgb(139, 92, 246);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.9;font-family:system-ui, sans-serif;font-size:16px;font-weight:500;text-anchor:middle;dominant-baseline:auto">Gemini</text>
    <!-- Grok -->
    <rect x="406" y="0" width="96" height="38" rx="19" fill="#1d9bf0" opacity="0.2" style="fill:rgb(29, 155, 240);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.2;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <rect x="406" y="0" width="96" height="38" rx="19" fill="none" stroke="#1d9bf0" stroke-width="1" opacity="0.4" style="fill:none;stroke:rgb(29, 155, 240);color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.4;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <text x="454" y="24" font-family="system-ui, sans-serif" font-size="16" font-weight="500" fill="#1d9bf0" text-anchor="middle" opacity="0.9" style="fill:rgb(29, 155, 240);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.9;font-family:system-ui, sans-serif;font-size:16px;font-weight:500;text-anchor:middle;dominant-baseline:auto">Grok</text>
    <!-- Codex -->
    <rect x="518" y="0" width="106" height="38" rx="19" fill="#10a37f" opacity="0.15" style="fill:rgb(16, 163, 127);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.15;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <rect x="518" y="0" width="106" height="38" rx="19" fill="none" stroke="#10a37f" stroke-width="1" opacity="0.3" style="fill:none;stroke:rgb(16, 163, 127);color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.3;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
    <text x="571" y="24" font-family="system-ui, sans-serif" font-size="16" font-weight="500" fill="#10a37f" text-anchor="middle" opacity="0.8" style="fill:rgb(16, 163, 127);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.8;font-family:system-ui, sans-serif;font-size:16px;font-weight:500;text-anchor:middle;dominant-baseline:auto">Codex</text>
  </g>

  <!-- Bottom URL -->
  <text x="600" y="578" font-family="system-ui, sans-serif" font-size="26" font-weight="500" fill="#475569" text-anchor="middle" letter-spacing="1" style="fill:rgb(71, 85, 105);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:system-ui, sans-serif;font-size:26px;font-weight:500;text-anchor:middle;dominant-baseline:auto">memephant.com</text>

  <!-- Local-first badge -->
  <rect x="880" y="440" width="230" height="46" rx="23" fill="#ffffff" opacity="0.05" style="fill:rgb(255, 255, 255);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.05;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <rect x="880" y="440" width="230" height="46" rx="23" fill="none" stroke="#ffffff" stroke-width="1" opacity="0.1" style="fill:none;stroke:rgb(255, 255, 255);color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:0.1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <text x="995" y="468" font-family="system-ui, sans-serif" font-size="15" font-weight="500" fill="#64748b" text-anchor="middle" style="fill:rgb(100, 116, 139);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:system-ui, sans-serif;font-size:15px;font-weight:500;text-anchor:middle;dominant-baseline:auto">Local-first · Private by default</text>

