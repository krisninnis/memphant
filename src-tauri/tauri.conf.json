{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Memephant",
  "version": "0.2.4",
  "identifier": "com.kris.memephant-desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Memephant",
        "width": 1100,
        "height": 700,
        "minWidth": 400,
        "minHeight": 500,
        "visible": true,
        "devtools": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVFM0Q4QzlEQzMwMkNBMUIKUldRYnlnTERuWXc5N3RwZll1Z0oyM29YV0Q2UWZQaXNrUEkxdFV5SGNlam9ROWR3ZEEwU2RFU08K",
      "endpoints": [
        "https://github.com/krisninnis/memphant/releases/latest/download/latest.json"
      ]
    }
  }
}
